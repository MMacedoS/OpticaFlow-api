### Configuracoes Iniciais (Variaveis)
@baseUrl = http://localhost:3000
@contentType = application/json

### 0. Login para obter token
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "email": "contato@opticaflow.com.br",
  "senha": "11222333000181"
}

###

@token = COLE_SEU_TOKEN
@empresaId = COLE_ID_EMPRESA
@filialId = COLE_ID_FILIAL
@pacientePessoaId = COLE_ID_PESSOA_PACIENTE
@profissionalUsuarioId = COLE_ID_USUARIO_PROFISSIONAL
@atendimentoId = COLE_ID_ATENDIMENTO
@prontuarioId = COLE_ID_PRONTUARIO

### ----------------------------------------------------------------------
### PRONTUARIO
### ----------------------------------------------------------------------

### 1. Criar prontuario completo
POST {{baseUrl}}/prontuario
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "empresaId": "{{empresaId}}",
  "filialId": "{{filialId}}",
  "atendimentoId": "{{atendimentoId}}",
  "pacienteId": "{{pacientePessoaId}}",
  "profissionalId": "{{profissionalUsuarioId}}",
  "resumo_clinico": "Paciente com queixa de visao embaçada e cefaleia no fim do dia.",
  "anamnese": {
    "historico_pessoal": "Uso ocasional de colirio lubrificante.",
    "historico_familiar": "Mae com historico de glaucoma.",
    "alergias": "Nao relatadas.",
    "medicamentos_uso": "Nenhum medicamento continuo.",
    "observacoes": "Paciente trabalha mais de 8 horas por dia no computador."
  },
  "acuidade_visual": {
    "od_sem_correcao": "20/40",
    "oe_sem_correcao": "20/30",
    "od_com_correcao": "20/25",
    "oe_com_correcao": "20/20",
    "observacoes": "Melhora com correcao de teste."
  },
  "refracao": {
    "od_esferico": "-1.00",
    "od_cilindrico": "-0.50",
    "od_eixo": "180",
    "oe_esferico": "-0.75",
    "oe_cilindrico": "-0.25",
    "oe_eixo": "170",
    "dp": "62",
    "adicao": "+1.00",
    "observacoes": "Boa adaptacao na refracao subjetiva."
  },
  "ceratometria": {
    "od_k1": "43.25",
    "od_k2": "44.00",
    "oe_k1": "43.00",
    "oe_k2": "43.75",
    "observacoes": "Sem irregularidades importantes."
  },
  "biomicroscopia": {
    "descricao": "Segmento anterior sem alteracoes relevantes."
  },
  "fundoscopia": {
    "descricao": "Papila corada, escavacao fisiologica preservada."
  },
  "pressao_intraocular": {
    "od_mmhg": 14,
    "oe_mmhg": 13,
    "horario": "2026-07-02T15:00:00.000Z",
    "observacoes": "Afericao sem intercorrencias."
  },
  "diagnosticos": [
    {
      "codigo": "H52.1",
      "versao": "CID10",
      "descricao": "Miopia"
    },
    {
      "codigo": "H52.2",
      "versao": "CID10",
      "descricao": "Astigmatismo"
    }
  ],
  "exames_complementares": [
    {
      "exame": "Topografia corneana",
      "resultado": "Padrao dentro da normalidade.",
      "dataExame": "2026-07-02T15:10:00.000Z"
    }
  ],
  "evolucoes_clinicas": [
    {
      "descricao": "Paciente orientado sobre uso de correcao optica e retorno em 6 meses.",
      "dataEvolucao": "2026-07-02T15:20:00.000Z"
    }
  ]
}

### 2. Listar prontuarios por filial com filtros opcionais
GET {{baseUrl}}/prontuario/filial/{{filialId}}?page=1&limit=10&search=miopia&pacienteId={{pacientePessoaId}}&profissionalId={{profissionalUsuarioId}}&atendimentoId={{atendimentoId}}&dataInicio=2026-07-01T00:00:00.000Z&dataFim=2026-07-31T23:59:59.999Z
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

### 2.1 Listar anamneses por filial com paginação e filtro por profissional
GET {{baseUrl}}/prontuario/filial/{{filialId}}/anamnese?page=1&limit=10&search=glaucoma&profissionalId={{profissionalUsuarioId}}&dataInicio=2026-07-01T00:00:00.000Z&dataFim=2026-07-31T23:59:59.999Z
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

### 2.2 Listar anamneses por profissional com filtro opcional por filial
GET {{baseUrl}}/prontuario/profissional/{{profissionalUsuarioId}}/anamnese?page=1&limit=10&search=ardencia&filialId={{filialId}}
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

### 3. Buscar prontuario por ID
GET {{baseUrl}}/prontuario/{{prontuarioId}}
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

### 4. Atualizar prontuario
PUT {{baseUrl}}/prontuario/{{prontuarioId}}
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "resumo_clinico": "Paciente com melhora parcial dos sintomas apos ajuste refracional.",
  "fundoscopia": {
    "descricao": "Fundoscopia mantida sem alteracoes patologicas."
  },
  "diagnosticos": [
    {
      "codigo": "H52.1",
      "versao": "CID10",
      "descricao": "Miopia atualizada"
    }
  ],
  "evolucoes_clinicas": [
    {
      "descricao": "Retorno antecipado se houver piora da cefaleia.",
      "dataEvolucao": "2026-07-10T10:00:00.000Z"
    }
  ]
}

### 4.1 Criar anamnese para prontuario existente
POST {{baseUrl}}/prontuario/{{prontuarioId}}/anamnese
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "historico_pessoal": "Paciente com uso esporadico de lagrima artificial.",
  "historico_familiar": "Pai com catarata.",
  "alergias": "Sem alergias conhecidas.",
  "medicamentos_uso": "Vitaminas.",
  "observacoes": "Refere ardencia ao final do dia."
}

### 4.2 Buscar anamnese por prontuario
GET {{baseUrl}}/prontuario/{{prontuarioId}}/anamnese
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

### 4.3 Atualizar anamnese por prontuario
PUT {{baseUrl}}/prontuario/{{prontuarioId}}/anamnese
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "historico_pessoal": "Paciente com uso diario de lubrificante ocular.",
  "historico_familiar": "Mae com glaucoma e pai com catarata.",
  "observacoes": "Mantem queixa visual associada a uso prolongado de telas."
}

### 4.4 Deletar anamnese por prontuario
DELETE {{baseUrl}}/prontuario/{{prontuarioId}}/anamnese
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

