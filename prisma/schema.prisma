generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Empresa {
  id                     String                 @id @default(cuid())
  nome                   String
  razao                  String
  cnpj                   String
  registro_estadual      String?
  registro_municipal     String?
  email                  String                 @unique
  website                String?
  status                 Status                 @default(ativo)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  acessos                Acesso[]
  agendas                Agenda[]
  arquivos               Arquivo[]
  atendimentos           Atendimento[]
  auditorias             Auditoria[]
  compras                Compra[]
  contatos               Contato_empresa[]
  convenios              Convenio[]
  enderecos              Endereco_empresa[]
  estoques               Estoque[]
  filiais                Filial[]
  financeiro_lancamentos FinanceiroLancamento[]
  laboratorios           Laboratorio[]
  movimentos_estoque     MovimentoEstoque[]
  notificacoes           Notificacao[]
  ordens_servico         OrdemServico[]
  permissoes             Permissao[]
  produtos               Produto[]
  prontuarios            Prontuario[]
  receitas               Receita[]
  usuarios               Usuario[]
  vendas                 Venda[]
}

model Endereco_empresa {
  id         String   @id @default(cuid())
  empresaId  String
  cep        String
  numero     String?
  logradouro String
  bairro     String
  cidade     String
  uf         String
  pais       String
  principal  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  empresa    Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, principal])
}

model Contato_empresa {
  id        String       @id @default(cuid())
  empresaId String
  tipo      TipoContatos @default(whatsapp)
  principal Boolean?     @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  contato   String       @default("")
  empresa   Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, tipo])
}

model Filial {
  id                     String                 @id @default(cuid())
  nome                   String
  cnpj                   String?
  empresaId              String
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  status                 Status                 @default(ativo)
  agendas                Agenda[]
  arquivos               Arquivo[]
  atendimentos           Atendimento[]
  auditorias             Auditoria[]
  compras                Compra[]
  config                 Config_filial?
  contatos               Contato_filial[]
  enderecos              Endereco_filial[]
  estoques               Estoque[]
  empresa                Empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  financeiro_lancamentos FinanceiroLancamento[]
  notificacoes           Notificacao[]
  ordens_servico         OrdemServico[]
  pessoas                Pessoa[]
  prontuarios            Prontuario[]
  receitas               Receita[]
  vendas                 Venda[]

  @@index([empresaId])
}

model Endereco_filial {
  id         String   @id @default(cuid())
  filialId   String
  cep        String
  numero     String?
  logradouro String
  bairro     String
  cidade     String
  uf         String
  pais       String
  principal  Boolean? @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  filial     Filial   @relation(fields: [filialId], references: [id], onDelete: Cascade)

  @@index([filialId, principal])
}

model Contato_filial {
  id        String       @id @default(cuid())
  filialId  String
  tipo      TipoContatos @default(whatsapp)
  principal Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  contato   String
  filial    Filial       @relation(fields: [filialId], references: [id], onDelete: Cascade)

  @@index([filialId, tipo])
}

model Config_filial {
  id       String  @id @default(cuid())
  filialId String  @unique
  timezone String?
  moeda    String?
  filial   Filial  @relation(fields: [filialId], references: [id], onDelete: Cascade)
}

model Pessoa {
  id              String          @id @default(cuid())
  nome            String
  cpf             String?         @unique
  email           String?
  filialId        String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  data_nascimento DateTime?       @default(now())
  genero          String?
  status          Status          @default(ativo)
  agendas         Agenda[]
  arquivos        Arquivo[]
  atendimentos    Atendimento[]   @relation("AtendimentoPaciente")
  cliente         Cliente?
  contatos        Contato[]
  documentos      Documento[]
  enderecos       Endereco[]
  fornecedor      Fornecedor?
  funcionario     Funcionario?
  notificacoes    Notificacao[]
  oftalmologista  Oftalmologista?
  optometrista    Optometrista?
  filial          Filial          @relation(fields: [filialId], references: [id], onDelete: Cascade)
  prontuarios     Prontuario[]
  receitas        Receita[]       @relation("ReceitaPaciente")
  responsavel     Responsavel?
  usuario         Usuario?

  @@index([filialId])
}

model Endereco {
  id         String   @id @default(cuid())
  pessoaId   String
  cep        String
  numero     String
  logradouro String
  bairro     String
  cidade     String
  uf         String
  pais       String
  principal  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  pessoa     Pessoa   @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  @@index([pessoaId, principal])
}

model Contato {
  id        String       @id @default(cuid())
  pessoaId  String
  tipo      TipoContatos @default(whatsapp)
  principal Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  contato   String
  pessoa    Pessoa       @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  @@index([pessoaId, tipo])
}

model Documento {
  id        String   @id @default(cuid())
  pessoaId  String
  tipo      String
  path      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pessoa    Pessoa   @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  @@index([pessoaId, tipo])
}

model Cliente {
  id              String         @id @default(cuid())
  pessoaId        String         @unique
  status          Status         @default(ativo)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  convenioId      String?
  numero_convenio String?
  atendimentos    Atendimento[]
  convenio        Convenio?      @relation(fields: [convenioId], references: [id])
  pessoa          Pessoa         @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
  ordens_servico  OrdemServico[]
  vendas          Venda[]

  @@index([convenioId])
}

model Funcionario {
  id        String   @id @default(cuid())
  pessoaId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cargo     String?
  pessoa    Pessoa   @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
}

model Optometrista {
  id                    String   @id @default(cuid())
  pessoaId              String   @unique
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  registro_profissional String
  pessoa                Pessoa   @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
}

model Oftalmologista {
  id                    String   @id @default(cuid())
  pessoaId              String   @unique
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  registro_profissional String
  pessoa                Pessoa   @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
}

model Fornecedor {
  id        String   @id @default(cuid())
  pessoaId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  compras   Compra[]
  pessoa    Pessoa   @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
}

model Responsavel {
  id        String   @id @default(cuid())
  pessoaId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pessoa    Pessoa   @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
}

model Usuario {
  id                        String                 @id @default(cuid())
  email                     String                 @unique
  senha                     String
  username                  String?                @unique
  status                    Status                 @default(ativo)
  ultimo_login              DateTime?
  pessoaId                  String?                @unique
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  empresaId                 String?
  agendas_profissional      Agenda[]               @relation("AgendaProfissional")
  arquivos_enviados         Arquivo[]              @relation("ArquivoEnviadoPor")
  atendimentos_profissional Atendimento[]          @relation("AtendimentoProfissional")
  atribuicao                Atribuicao[]
  auditorias                Auditoria[]
  financeiro_lancamentos    FinanceiroLancamento[] @relation("FinanceiroCriadoPor")
  notificacoes_destino      Notificacao[]          @relation("NotificacaoDestino")
  notificacoes_remetente    Notificacao[]          @relation("NotificacaoRemetente")
  prontuarios_profissional  Prontuario[]           @relation("ProntuarioProfissional")
  receitas_profissional     Receita[]              @relation("ReceitaProfissional")
  empresa                   Empresa?               @relation(fields: [empresaId], references: [id])
  pessoa                    Pessoa?                @relation(fields: [pessoaId], references: [id])

  @@index([empresaId])
}

model Acesso {
  id         String            @id @default(cuid())
  nome       String            @unique
  descricao  String?
  empresaId  String?
  empresa    Empresa?          @relation(fields: [empresaId], references: [id])
  permissao  AcessoPermissao[]
  atribuicao Atribuicao[]

  @@index([empresaId])
}

model Permissao {
  id        String            @id @default(cuid())
  modulo    String
  acao      String
  descricao String?
  empresaId String?
  acesso    AcessoPermissao[]
  empresa   Empresa?          @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, modulo, acao])
  @@index([empresaId])
}

model Atribuicao {
  id        String  @id @default(cuid())
  usuarioId String
  acessoId  String
  acesso    Acesso  @relation(fields: [acessoId], references: [id])
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, acessoId])
}

model AcessoPermissao {
  id          String    @id @default(cuid())
  acessoId    String
  permissaoId String
  acesso      Acesso    @relation(fields: [acessoId], references: [id])
  permissao   Permissao @relation(fields: [permissaoId], references: [id])

  @@unique([acessoId, permissaoId])
}

model Agenda {
  id             String       @id @default(cuid())
  empresaId      String
  filialId       String
  pessoaId       String?
  profissionalId String?
  dataHora       DateTime
  duracaoMin     Int?
  status         StatusAgenda @default(agendado)
  observacao     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  empresa        Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  filial         Filial       @relation(fields: [filialId], references: [id], onDelete: Cascade)
  pessoa         Pessoa?      @relation(fields: [pessoaId], references: [id])
  profissional   Usuario?     @relation("AgendaProfissional", fields: [profissionalId], references: [id])
  atendimento    Atendimento?

  @@index([empresaId, dataHora])
  @@index([filialId, dataHora])
  @@index([pessoaId])
  @@index([profissionalId])
}

model Atendimento {
  id               String                 @id @default(cuid())
  empresaId        String
  filialId         String
  agendaId         String?                @unique
  pacienteId       String
  profissionalId   String?
  clienteId        String?
  convenioId       String?
  dataAtendimento  DateTime               @default(now())
  status           StatusAtendimento      @default(em_espera)
  queixa_principal String?
  observacoes      String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  arquivos         Arquivo[]
  agenda           Agenda?                @relation(fields: [agendaId], references: [id])
  cliente          Cliente?               @relation(fields: [clienteId], references: [id])
  convenio         Convenio?              @relation(fields: [convenioId], references: [id])
  empresa          Empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  filial           Filial                 @relation(fields: [filialId], references: [id], onDelete: Cascade)
  paciente         Pessoa                 @relation("AtendimentoPaciente", fields: [pacienteId], references: [id], onDelete: Cascade)
  profissional     Usuario?               @relation("AtendimentoProfissional", fields: [profissionalId], references: [id])
  auditorias       Auditoria[]
  financeiro       FinanceiroLancamento[]
  ordens_servico   OrdemServico[]
  prontuario       Prontuario?
  receitas         Receita[]
  vendas           Venda[]

  @@index([empresaId, dataAtendimento])
  @@index([filialId, dataAtendimento])
  @@index([pacienteId])
  @@index([profissionalId])
  @@index([clienteId])
  @@index([convenioId])
}

model Prontuario {
  id                    String                        @id @default(cuid())
  empresaId             String
  filialId              String
  atendimentoId         String                        @unique
  pacienteId            String
  profissionalId        String?
  resumo_clinico        String?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  arquivos              Arquivo[]
  atendimento           Atendimento                   @relation(fields: [atendimentoId], references: [id], onDelete: Cascade)
  empresa               Empresa                       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  filial                Filial                        @relation(fields: [filialId], references: [id], onDelete: Cascade)
  paciente              Pessoa                        @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  profissional          Usuario?                      @relation("ProntuarioProfissional", fields: [profissionalId], references: [id])
  acuidade_visual       ProntuarioAcuidadeVisual?
  anamnese              ProntuarioAnamnese?
  biomicroscopia        ProntuarioBiomicroscopia?
  ceratometria          ProntuarioCeratometria?
  diagnosticos          ProntuarioDiagnostico[]
  evolucoes_clinicas    ProntuarioEvolucaoClinica[]
  exames_complementares ProntuarioExameComplementar[]
  fundoscopia           ProntuarioFundoscopia?
  pressao_intraocular   ProntuarioPressaoIntraocular?
  refracao              ProntuarioRefracao?
  receitas              Receita[]

  @@index([empresaId])
  @@index([filialId])
  @@index([pacienteId])
  @@index([profissionalId])
}

model ProntuarioAnamnese {
  id                 String     @id @default(cuid())
  prontuarioId       String     @unique
  historico_pessoal  String?
  historico_familiar String?
  alergias           String?
  medicamentos_uso   String?
  observacoes        String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  prontuario         Prontuario @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)
}

model ProntuarioAcuidadeVisual {
  id              String     @id @default(cuid())
  prontuarioId    String     @unique
  od_sem_correcao String?
  oe_sem_correcao String?
  od_com_correcao String?
  oe_com_correcao String?
  observacoes     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  prontuario      Prontuario @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)
}

model ProntuarioRefracao {
  id            String     @id @default(cuid())
  prontuarioId  String     @unique
  od_esferico   String?
  od_cilindrico String?
  od_eixo       String?
  oe_esferico   String?
  oe_cilindrico String?
  oe_eixo       String?
  dp            String?
  adicao        String?
  observacoes   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  prontuario    Prontuario @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)
}

model ProntuarioCeratometria {
  id           String     @id @default(cuid())
  prontuarioId String     @unique
  od_k1        String?
  od_k2        String?
  oe_k1        String?
  oe_k2        String?
  observacoes  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  prontuario   Prontuario @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)
}

model ProntuarioBiomicroscopia {
  id           String     @id @default(cuid())
  prontuarioId String     @unique
  descricao    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  prontuario   Prontuario @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)
}

model ProntuarioFundoscopia {
  id           String     @id @default(cuid())
  prontuarioId String     @unique
  descricao    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  prontuario   Prontuario @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)
}

model ProntuarioPressaoIntraocular {
  id           String     @id @default(cuid())
  prontuarioId String     @unique
  od_mmhg      Float?
  oe_mmhg      Float?
  horario      DateTime?
  observacoes  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  prontuario   Prontuario @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)
}

model ProntuarioDiagnostico {
  id           String     @id @default(cuid())
  prontuarioId String
  codigo       String
  versao       String
  descricao    String?
  createdAt    DateTime   @default(now())
  prontuario   Prontuario @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)

  @@index([prontuarioId])
  @@index([codigo, versao])
}

model ProntuarioExameComplementar {
  id           String     @id @default(cuid())
  prontuarioId String
  exame        String
  resultado    String?
  dataExame    DateTime?
  createdAt    DateTime   @default(now())
  prontuario   Prontuario @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)

  @@index([prontuarioId])
}

model ProntuarioEvolucaoClinica {
  id           String     @id @default(cuid())
  prontuarioId String
  descricao    String
  dataEvolucao DateTime   @default(now())
  createdAt    DateTime   @default(now())
  prontuario   Prontuario @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)

  @@index([prontuarioId, dataEvolucao])
}

model Receita {
  id             String               @id @default(cuid())
  empresaId      String
  filialId       String
  atendimentoId  String?
  prontuarioId   String?
  pacienteId     String
  profissionalId String?
  tipo           TipoReceita
  observacoes    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  atendimento    Atendimento?         @relation(fields: [atendimentoId], references: [id])
  empresa        Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  filial         Filial               @relation(fields: [filialId], references: [id], onDelete: Cascade)
  paciente       Pessoa               @relation("ReceitaPaciente", fields: [pacienteId], references: [id], onDelete: Cascade)
  profissional   Usuario?             @relation("ReceitaProfissional", fields: [profissionalId], references: [id])
  prontuario     Prontuario?          @relation(fields: [prontuarioId], references: [id])
  lente_contato  ReceitaLenteContato?
  medicamento    ReceitaMedicamento?
  oculos         ReceitaOculos?

  @@index([empresaId, tipo])
  @@index([filialId])
  @@index([atendimentoId])
  @@index([prontuarioId])
  @@index([pacienteId])
  @@index([profissionalId])
}

model ReceitaOculos {
  id            String  @id @default(cuid())
  receitaId     String  @unique
  od_esferico   String?
  od_cilindrico String?
  od_eixo       String?
  oe_esferico   String?
  oe_cilindrico String?
  oe_eixo       String?
  dp            String?
  adicao        String?
  observacoes   String?
  receita       Receita @relation(fields: [receitaId], references: [id], onDelete: Cascade)
}

model ReceitaLenteContato {
  id            String  @id @default(cuid())
  receitaId     String  @unique
  od_curva_base String?
  od_diametro   String?
  od_grau       String?
  oe_curva_base String?
  oe_diametro   String?
  oe_grau       String?
  material      String?
  marca         String?
  observacoes   String?
  receita       Receita @relation(fields: [receitaId], references: [id], onDelete: Cascade)
}

model ReceitaMedicamento {
  id          String  @id @default(cuid())
  receitaId   String  @unique
  medicamento String
  dosagem     String?
  posologia   String?
  duracao     String?
  observacoes String?
  receita     Receita @relation(fields: [receitaId], references: [id], onDelete: Cascade)
}

model Produto {
  id                  String             @id @default(cuid())
  empresaId           String
  nome                String
  sku                 String
  tipo                TipoProduto
  categoria           String?
  descricao           String?
  preco_custo         Float?
  preco_venda         Float
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  ativo               Status             @default(ativo)
  margem_lucro        Float?             @default(0)
  compra_itens        CompraItem[]
  estoque_itens       EstoqueItem[]
  movimentos          MovimentoEstoque[]
  ordem_servico_itens OrdemServicoItem[]
  empresa             Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  venda_itens         VendaItem[]

  @@unique([empresaId, sku])
  @@index([empresaId, tipo])
}

model Estoque {
  id         String             @id @default(cuid())
  empresaId  String
  filialId   String
  nome       String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  empresa    Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  filial     Filial             @relation(fields: [filialId], references: [id], onDelete: Cascade)
  itens      EstoqueItem[]
  movimentos MovimentoEstoque[]

  @@unique([empresaId, filialId])
}

model EstoqueItem {
  id         String   @id @default(cuid())
  estoqueId  String
  produtoId  String
  quantidade Float    @default(0)
  minimo     Float?
  maximo     Float?
  updatedAt  DateTime @updatedAt
  estoque    Estoque  @relation(fields: [estoqueId], references: [id], onDelete: Cascade)
  produto    Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([estoqueId, produtoId])
  @@index([produtoId])
}

model MovimentoEstoque {
  id         String               @id @default(cuid())
  empresaId  String
  estoqueId  String
  produtoId  String
  tipo       TipoMovimentoEstoque
  quantidade Float
  motivo     String?
  referencia String?
  createdAt  DateTime             @default(now())
  empresa    Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  estoque    Estoque              @relation(fields: [estoqueId], references: [id], onDelete: Cascade)
  produto    Produto              @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([empresaId, createdAt])
  @@index([estoqueId, createdAt])
  @@index([produtoId, createdAt])
}

model Compra {
  id           String                 @id @default(cuid())
  empresaId    String
  filialId     String
  fornecedorId String?
  dataCompra   DateTime               @default(now())
  status       String?
  valor_total  Float                  @default(0)
  observacoes  String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  empresa      Empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  filial       Filial                 @relation(fields: [filialId], references: [id], onDelete: Cascade)
  fornecedor   Fornecedor?            @relation(fields: [fornecedorId], references: [id])
  itens        CompraItem[]
  financeiro   FinanceiroLancamento[]

  @@index([empresaId, dataCompra])
  @@index([filialId, dataCompra])
  @@index([fornecedorId])
}

model CompraItem {
  id             String  @id @default(cuid())
  compraId       String
  produtoId      String
  quantidade     Float
  valor_unitario Float
  desconto       Float?
  compra         Compra  @relation(fields: [compraId], references: [id], onDelete: Cascade)
  produto        Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([compraId])
  @@index([produtoId])
}

model Venda {
  id            String                 @id @default(cuid())
  empresaId     String
  filialId      String
  clienteId     String?
  atendimentoId String?
  dataVenda     DateTime               @default(now())
  status        String?
  valor_total   Float                  @default(0)
  observacoes   String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  financeiro    FinanceiroLancamento[]
  atendimento   Atendimento?           @relation(fields: [atendimentoId], references: [id])
  cliente       Cliente?               @relation(fields: [clienteId], references: [id])
  empresa       Empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  filial        Filial                 @relation(fields: [filialId], references: [id], onDelete: Cascade)
  itens         VendaItem[]

  @@index([empresaId, dataVenda])
  @@index([filialId, dataVenda])
  @@index([clienteId])
  @@index([atendimentoId])
}

model VendaItem {
  id             String  @id @default(cuid())
  vendaId        String
  produtoId      String
  quantidade     Float
  valor_unitario Float
  desconto       Float?
  produto        Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  venda          Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)

  @@index([vendaId])
  @@index([produtoId])
}

model Laboratorio {
  id             String         @id @default(cuid())
  empresaId      String
  nome           String
  cnpj           String?
  email          String?
  telefone       String?
  ativo          Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  empresa        Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  ordens_servico OrdemServico[]

  @@index([empresaId])
}

model OrdemServico {
  id               String                 @id @default(cuid())
  empresaId        String
  filialId         String
  atendimentoId    String?
  clienteId        String?
  laboratorioId    String?
  numero           String?
  status           StatusOrdemServico     @default(aberta)
  descricao        String?
  previsao_entrega DateTime?
  data_entrega     DateTime?
  valor_total      Float                  @default(0)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  financeiro       FinanceiroLancamento[]
  atendimento      Atendimento?           @relation(fields: [atendimentoId], references: [id])
  cliente          Cliente?               @relation(fields: [clienteId], references: [id])
  empresa          Empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  filial           Filial                 @relation(fields: [filialId], references: [id], onDelete: Cascade)
  laboratorio      Laboratorio?           @relation(fields: [laboratorioId], references: [id])
  itens            OrdemServicoItem[]

  @@index([empresaId, status])
  @@index([filialId])
  @@index([clienteId])
  @@index([atendimentoId])
  @@index([laboratorioId])
}

model OrdemServicoItem {
  id                String       @id @default(cuid())
  ordemServicoId    String
  produtoId         String?
  descricao_servico String?
  quantidade        Float
  valor_unitario    Float
  desconto          Float?
  ordem_servico     OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  produto           Produto?     @relation(fields: [produtoId], references: [id])

  @@index([ordemServicoId])
  @@index([produtoId])
}

model Convenio {
  id           String        @id @default(cuid())
  empresaId    String
  nome         String
  registro     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ativo        Status        @default(ativo)
  atendimentos Atendimento[]
  clientes     Cliente[]
  empresa      Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
}

model FinanceiroLancamento {
  id             String         @id @default(cuid())
  empresaId      String
  filialId       String?
  atendimentoId  String?
  vendaId        String?
  compraId       String?
  ordemServicoId String?
  criadoPorId    String?
  tipo           TipoFinanceiro
  categoria      String?
  descricao      String?
  valor          Float
  vencimento     DateTime?
  pagoEm         DateTime?
  status         String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  atendimento    Atendimento?   @relation(fields: [atendimentoId], references: [id])
  compra         Compra?        @relation(fields: [compraId], references: [id])
  criado_por     Usuario?       @relation("FinanceiroCriadoPor", fields: [criadoPorId], references: [id])
  empresa        Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  filial         Filial?        @relation(fields: [filialId], references: [id])
  ordem_servico  OrdemServico?  @relation(fields: [ordemServicoId], references: [id])
  venda          Venda?         @relation(fields: [vendaId], references: [id])

  @@index([empresaId, tipo, createdAt])
  @@index([filialId])
  @@index([atendimentoId])
  @@index([vendaId])
  @@index([compraId])
  @@index([ordemServicoId])
  @@index([criadoPorId])
}

model Arquivo {
  id            String       @id @default(cuid())
  empresaId     String
  filialId      String?
  pessoaId      String?
  atendimentoId String?
  prontuarioId  String?
  enviadoPorId  String?
  nome          String
  path          String
  mime_type     String?
  tamanho       Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  atendimento   Atendimento? @relation(fields: [atendimentoId], references: [id])
  empresa       Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  enviado_por   Usuario?     @relation("ArquivoEnviadoPor", fields: [enviadoPorId], references: [id])
  filial        Filial?      @relation(fields: [filialId], references: [id])
  pessoa        Pessoa?      @relation(fields: [pessoaId], references: [id])
  prontuario    Prontuario?  @relation(fields: [prontuarioId], references: [id])

  @@index([empresaId, createdAt])
  @@index([filialId])
  @@index([pessoaId])
  @@index([atendimentoId])
  @@index([prontuarioId])
  @@index([enviadoPorId])
}

model Notificacao {
  id                 String           @id @default(cuid())
  empresaId          String
  filialId           String?
  pessoaId           String?
  usuarioDestinoId   String?
  usuarioRemetenteId String?
  canal              CanalNotificacao @default(sistema)
  titulo             String
  mensagem           String
  lidaEm             DateTime?
  createdAt          DateTime         @default(now())
  empresa            Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  filial             Filial?          @relation(fields: [filialId], references: [id])
  pessoa             Pessoa?          @relation(fields: [pessoaId], references: [id])
  usuario_destino    Usuario?         @relation("NotificacaoDestino", fields: [usuarioDestinoId], references: [id])
  usuario_remetente  Usuario?         @relation("NotificacaoRemetente", fields: [usuarioRemetenteId], references: [id])

  @@index([empresaId, createdAt])
  @@index([usuarioDestinoId, lidaEm])
  @@index([filialId])
  @@index([pessoaId])
}

model Auditoria {
  id            String       @id @default(cuid())
  empresaId     String
  filialId      String?
  usuarioId     String?
  atendimentoId String?
  entidade      String
  entidadeId    String?
  acao          String
  dados_antes   Json?
  dados_depois  Json?
  ip            String?
  user_agent    String?
  createdAt     DateTime     @default(now())
  atendimento   Atendimento? @relation(fields: [atendimentoId], references: [id])
  empresa       Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  filial        Filial?      @relation(fields: [filialId], references: [id])
  usuario       Usuario?     @relation(fields: [usuarioId], references: [id])

  @@index([empresaId, createdAt])
  @@index([filialId])
  @@index([usuarioId])
  @@index([atendimentoId])
  @@index([entidade, entidadeId])
}

enum TipoContatos {
  whatsapp
  telefone
  celular
}

enum Status {
  ativo
  inativo
}

enum StatusAgenda {
  agendado
  confirmado
  cancelado
  concluido
  falta
}

enum StatusAtendimento {
  em_espera
  em_andamento
  concluido
  cancelado
}

enum TipoReceita {
  oculos
  lente_contato
  medicamento
}

enum TipoProduto {
  armacao
  lente
  acessorio
  servico
}

enum TipoMovimentoEstoque {
  entrada
  saida
  ajuste
}

enum StatusOrdemServico {
  aberta
  orcamento
  faturada
  finalizada
  cancelada
}

enum TipoFinanceiro {
  receita
  despesa
}

enum CanalNotificacao {
  sistema
  email
  whatsapp
  sms
}
